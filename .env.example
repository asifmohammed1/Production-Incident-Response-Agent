# ─── Ollama ───────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral                     # or llama3, deepseek-coder

# ─── HuggingFace ──────────────────────────────────────
HF_MODEL_NAME=bert-base-uncased          # LogBERT or custom fine-tuned
HF_ANOMALY_THRESHOLD=0.85

# ─── PostgreSQL ───────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=incident_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=yourpassword

# ─── MongoDB ──────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=incident_history

# ─── ChromaDB ─────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_store

# ─── Slack ────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_ALERT_CHANNEL=#incidents

# ─── GitHub / Jira (MCP Tools) ────────────────────────
GITHUB_TOKEN=your-github-token
GITHUB_REPO=org/repo-name
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=your-jira-token
JIRA_PROJECT_KEY=INC

# ─── Log Sources ──────────────────────────────────────
LOG_WATCH_DIR=./datasets/sample_logs
LOG_STREAM_INTERVAL=5                    # seconds

# ─── PySpark ──────────────────────────────────────────
SPARK_MASTER=local[*]
SPARK_APP_NAME=IncidentResponseAgent
